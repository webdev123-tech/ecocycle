# ===== EcoCycle server config =====
PORT=4000
PUBLIC_URL=http://localhost:4000
JWT_SECRET=generate-with-node-crypto-randomBytes

# ---- Persistent database (Turso) ----
# Leave BOTH blank for local dev (uses a local SQLite file that persists on disk).
# In production (Render), set these to make accounts/data survive every restart &
# redeploy. Create a free DB at turso.tech, then:
#   turso db create ecocycle
#   turso db show ecocycle --url        -> TURSO_DATABASE_URL (libsql://...)
#   turso db tokens create ecocycle     -> TURSO_AUTH_TOKEN
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# ---- SMS (Africa's Talking — Uganda) : fill to enable real OTP SMS ----
AT_USERNAME=
AT_API_KEY=
AT_SENDER_ID=
# ---- OR Twilio ----
TWILIO_SID=
TWILIO_TOKEN=
TWILIO_FROM=

# ---- Email (SMTP, e.g. Gmail app password) ----
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=EcoCycle <no-reply@ecocycle.ug>

# ---- Payments (Flutterwave) ----
FLW_SECRET_KEY=
FLW_PUBLIC_KEY=
FLW_CURRENCY=UGX

# ---- Google OAuth (Web client ID) ----
GOOGLE_CLIENT_ID=
